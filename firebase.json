{
    "firestore":  {
                      "rules":  "firestore.rules"
                  },
    "hosting":  {
                    "public":  "dist",
                    "ignore":  [
                                   "firebase.json",
                                   "**/.*",
                                   "**/node_modules/**"
                               ],
                    "rewrites":  [
                                     {
                                         "source":  "**",
                                         "destination":  "/index.html"
                                     },
                                     {
                                         "source":  "/answer/**",
                                         "destination":  "/answer/[id]/index.html"
                                     }
                                 ]
                }
}
